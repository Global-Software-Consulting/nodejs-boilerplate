{
  "name": "@gsoft/backend",
  "version": "1.0.0",
  "private": true,
  "description": "GSoft backend API service",
  "main": "src/index.js",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.json --no-daemon",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "test": "jest -i --colors --verbose --detectOpenHandles",
    "test:ci": "jest -i --ci --coverage",
    "test:watch": "jest -i --watchAll",
    "coverage": "jest -i --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "docker:prod": "docker-compose -f docker/docker-compose.yml -f docker/docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker/docker-compose.yml -f docker/docker-compose.test.yml up"
  },
  "dependencies": {
    "@sentry/node": "10",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-status": "^2.1.0",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.24.0",
    "mongoose": "^9.3.3",
    "morgan": "^1.9.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pm2": "^6.0.14",
    "swagger-jsdoc": "^6.0.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.0.0",
    "winston": "^3.2.1",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "faker": "^6.6.6",
    "jest": "^30.3.0",
    "node-mocks-http": "^1.8.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
