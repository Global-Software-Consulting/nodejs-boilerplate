{
  "name": "@gsoft/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "GSoft Node.js monorepo",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @gsoft/backend dev",
    "dev:frontend": "pnpm --filter @gsoft/frontend dev",
    "dev:all": "pnpm -r dev",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "release": "semantic-release",
    "setup": "bash setup.sh",
    "docker:temporal": "docker compose -f docker/docker-compose.temporal.yml up -d",
    "docker:temporal:down": "docker compose -f docker/docker-compose.temporal.yml down",
    "docker:n8n": "docker compose -f docker/docker-compose.n8n.yml up -d",
    "docker:n8n:down": "docker compose -f docker/docker-compose.n8n.yml down",
    "docker:node-red": "docker compose -f docker/docker-compose.node-red.yml up -d",
    "docker:node-red:down": "docker compose -f docker/docker-compose.node-red.yml down",
    "docker:restate": "docker compose -f docker/docker-compose.restate.yml up -d",
    "docker:restate:down": "docker compose -f docker/docker-compose.restate.yml down"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^28.0.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-security": "^3.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^24.0.0"
  }
}
